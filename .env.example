# =============================================
# Go High Level — Variables de entorno
# =============================================

# 1. API Key de AGENCIA (no la de sub-cuenta)
#    GHL > Agency Settings > API Keys
GHL_API_KEY=tu_agency_api_key_aqui

# 2. Company ID de tu agencia
#    GHL > Agency Settings > Company ID
#    O míralo en la URL: app.gohighlevel.com/agency/ESTE_ES_EL_ID/...
GHL_COMPANY_ID=tu_company_id_aqui
